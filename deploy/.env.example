# ---- Deployment environment (copy to `.env` on the target machine) ----

# Where to pull images from, and which tag. Point these at your registry.
IMAGE_PREFIX=ghcr.io/phdwight
IMAGE_TAG=latest

# --- Postgres (change the password!) ---
POSTGRES_USER=insurance
POSTGRES_PASSWORD=change-me-please
POSTGRES_DB=insurance
# Must exactly match the three values above (host stays `postgres`):
DATABASE_URL=postgresql+psycopg://insurance:change-me-please@postgres:5432/insurance

# --- Public URLs: how BROWSERS reach this host ---
# For local testing keep localhost. For a server, use its IP/domain, e.g.
#   VITE_API_URL=http://203.0.113.10:8000
#   CORS_ORIGINS=http://203.0.113.10:5173
VITE_API_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:5173

# Optional: change published host ports
# API_PORT=8000
# INGESTION_PORT=8003
# PWA_PORT=5173

# --- LLM providers (agent chat + document extraction). Set at least one key ---
LLM_MODEL=anthropic:claude-sonnet-4-5
LLM_MODEL_SMALL=anthropic:claude-haiku-4-5
VERIFIER_MODELS=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Embeddings (optional; search falls back to SQL ranking without a key) ---
VOYAGE_API_KEY=
EMBEDDING_MODEL=voyage-3.5
EMBEDDING_DIM=1024

# --- Ingestion admin protection (REQUIRED for any non-local deploy) ---
# Empty token = OPEN admin surface. Set a strong random value on a server.
ADMIN_TOKEN=

# --- LangSmith tracing (optional) ---
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=insurance-recommender
