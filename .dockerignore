# Build-context excludes for the Python images (Dockerfile.python does COPY . .
# from the repo root). Without this, the local dev .venv (~1.3G), node_modules,
# .git, caches, and — critically — .env (secrets) get baked into every image.

# Secrets — must never be baked into an image (these images are published)
.env
.env.*
!.env.example

# Local virtualenv — uv rebuilds it in-image via `uv sync`
.venv

# Node / PWA — not needed by the Python images; the PWA has its own build context
**/node_modules
pwa/dist

# VCS & CI
.git
.gitignore
.github

# Python caches
**/__pycache__
**/*.pyc
**/*.pyo
.pytest_cache
.ruff_cache
.mypy_cache

# OS / editor cruft
.DS_Store
