# Copy to .env and fill in secrets. docker-compose reads this automatically.

# Postgres
POSTGRES_USER=insurance
POSTGRES_PASSWORD=insurance
POSTGRES_DB=insurance
# Keep this in sync with POSTGRES_PASSWORD above. docker-compose.prod.yml derives
# DATABASE_URL from POSTGRES_PASSWORD automatically when it is left UNSET, so for
# a production deploy you can comment this line out and only set the password.
DATABASE_URL=postgresql+psycopg://insurance:insurance@postgres:5432/insurance

# LLM — provider-agnostic (LangChain init_chat_model format: "provider:model")
# Examples — Anthropic: anthropic:claude-opus-4-8, anthropic:claude-sonnet-4-5,
#            anthropic:claude-haiku-4-5 · OpenAI: openai:gpt-4o, openai:gpt-4o-mini
#
# ── Model roster: 6 models in 3 tiers, two per tier ─────────────────────────
# The app uses each tier's _1 slot. The _2 slot is a vetted alternate — to
# switch, copy its value up into _1 (ideally a different provider, for resilience
# and to keep the verifier judges cross-provider vs the writer). Match tier to
# what each role demands; a bigger model costs more per call.
#
#   large  = the "writer": user-facing match explanations. Groundedness depends
#            on strict only-cite-provided-fields instructions; weaker models drift.
LLM_MODEL_LARGE_1=anthropic:claude-opus-4-8
LLM_MODEL_LARGE_2=openai:gpt-4o
#   mid    = ingestion vision triage + intake gate + auto-correction. Needs solid
#            judgment and vision, but doesn't need the frontier writer's polish.
LLM_MODEL_MID_1=anthropic:claude-sonnet-4-5
LLM_MODEL_MID_2=openai:gpt-4o-mini
#   small  = the "extractor": maps text into a structured NeedsProfile / policy
#            draft (constrained output). Runs often — cost & latency matter most.
LLM_MODEL_SMALL_1=anthropic:claude-haiku-4-5
LLM_MODEL_SMALL_2=openai:gpt-4o-mini
#
# Migration: the older single LLM_MODEL (writer) and LLM_MODEL_SMALL (extractor)
# are still honored as the large/small fallback when the _1 slots above are unset,
# so an existing .env keeps working. Prefer the tiered slots for new setups.
#
# Any OpenAI model is routed through the Responses API automatically — OpenAI
# reasoning models reject function tools (which structured output needs) on the
# older chat-completions endpoint.
#
# Guided mode uses NO LLM at all — questions and answer parsing are
# deterministic — so the app runs with zero keys (free-form disabled).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Ingestion vision triage — the mid-tier model looks at each uploaded PDF and
# either transcribes image-heavy/scanned docs to Markdown itself or routes to
# docling (clean text/tables). 'auto' = on when an LLM key is set; 'false' =
# always docling. VISION_MAX_PAGES caps pages sent to the model (cost).
VISION_TRIAGE=auto
VISION_MAX_PAGES=8
# Intake gate — the mid-tier model rejects non-insurance uploads outright and
# redacts personal info (PII) from the text before extraction. 'auto' = on when
# an LLM key is set; 'false' disables (accept all, no redaction).
INTAKE_GATE=auto

# Agent scaling knobs (see docs/06-scaling.md). AGENT_DB_POOL_SIZE sizes the
# shared Postgres pool (checkpointer + caches + ledger); budget pool × replicas
# under Postgres max_connections (default 100). CATALOG_CACHE_SECONDS memoizes
# read-only catalog calls per turn (0 = off); a newly published policy reaches
# fresh conversations within this window.
AGENT_DB_POOL_SIZE=10
CATALOG_CACHE_SECONDS=60

# Daily LLM token budget (input+output, all models) — the spend alarm. When
# the day's total in app.llm_usage crosses it, the agent logs a WARNING (once
# per day) suggesting an LLM_ECONOMY downshift; GET /ops/usage reports
# over_budget. 0 or empty = no budget. Observability only — nothing is blocked.
DAILY_TOKEN_BUDGET=0

# LLM economy ladder — the kill switch for a spend spike. 'full' (default) =
# writer + judge panel + extractor as designed; 'lean' = drop the judge panel
# (it only ever makes output stricter, so skipping is safe); 'deterministic' =
# zero LLM calls — explanations render from verified catalog fields via
# templates and profile parsing is deterministic-only. Every rung stays honest
# and fully usable. Flip via env + container restart; no rebuild.
LLM_ECONOMY=full

# Explanation cache — the writer + judge panel run once per outcome bucket
# (same profile answers vs the same policy versions), then Postgres serves the
# verified result to every later user in that bucket. Content-addressed, so a
# policy re-version or model/prompt change self-invalidates. 'off' disables;
# otherwise on whenever DATABASE_URL is set. Rows unused past the TTL are
# purged by the agent's hourly retention task.
EXPLANATION_CACHE=auto
EXPLANATION_CACHE_TTL_DAYS=30

# VERIFIER_MODELS (the "judges") — small models are fine; the task is a
#   narrow yes/no fact-check against provided JSON. What matters is:
#   * at least 2 judges (unanimous vote required), and
#   * different providers than the writer, to avoid self-consistency bias
#     (a model tends to approve its own phrasing).
#   Empty = verifier panel disabled (explanations ship unreviewed).
VERIFIER_MODELS=anthropic:claude-haiku-4-5,openai:gpt-4o-mini

# Embeddings (voyage-3.5 @ 1024 dims; optional — search falls back to SQL ranking)
VOYAGE_API_KEY=
EMBEDDING_MODEL=voyage-3.5
EMBEDDING_DIM=1024

# Ingestion admin token — REQUIRED before exposing :8003 beyond localhost.
# Locks the whole data surface (uploads, reviews, documents); the reviewer UI
# prompts for it. Empty = open (local development only).
ADMIN_TOKEN=

# LangSmith tracing (free tier: smith.langchain.com). Traces every LLM call —
# agent chat + verifier panel and ingestion extraction (both auto-instrumented
# by LangChain). Only set true WITH a valid key — true + empty key spams 401
# errors in the agent/worker logs. All traces land in LANGSMITH_PROJECT.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=insurance-recommender
# API region: default is US SaaS. Use the EU endpoint
# (https://eu.api.smith.langchain.com) or a self-hosted URL if that's where your
# account lives — otherwise traces silently go nowhere.
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# --- Public URLs (REQUIRED by docker-compose.prod.yml; the dev compose defaults
#     these itself and ignores them here) ---
#
# The browser calls the API directly, so both must be the API's PUBLIC address
# as seen from the user's browser — NOT the internal service name.
#
# CORS_ORIGINS — comma-separated PWA origin(s) the API accepts cross-origin
#   requests from (the address bar the user visits, no trailing slash).
# VITE_API_URL — the API base URL the PWA fetches from; rendered into the
#   static build's /config.js at container start.
# VITE_INGESTION_URL — OPTIONAL public ingestion base URL. Enables brochure
#   cover thumbnails + document links in results (the PWA loads
#   {VITE_INGESTION_URL}/policies/{slug}/brochure). Empty = feature off (cards
#   show a "No brochure available" placeholder). MUST be https when the PWA is
#   https, or the browser blocks the cover image as mixed content.
#
# Local prod-compose test with the default 41500 ports:
CORS_ORIGINS=http://localhost:41500
VITE_API_URL=http://localhost:41501
VITE_INGESTION_URL=http://localhost:41502
# Real deploy behind TLS, e.g.:
#   CORS_ORIGINS=https://insurance.example.com
#   VITE_API_URL=https://api.insurance.example.com
#   VITE_INGESTION_URL=https://ingest.insurance.example.com

# /chat rate limit at the API gateway — the only endpoint that can spend LLM
# tokens. "requests/seconds" per client (first X-Forwarded-For hop, else peer
# IP). A human sends a few messages a minute; scripts hammering it are token
# burn. 'off' disables (local dev). Per-process by design (one uvicorn worker
# per container).
RATE_LIMIT_CHAT=30/60


# ===========================================================================
# Optional tuning — everything below has a sensible default and is NOT required.
# Uncomment only to override. Values shown are the built-in defaults.
# ===========================================================================

# --- Ingestion ---
# DOCLING_ENABLED — set false/0/off to force the light pypdf path and skip the
#   heavy docling layout/table models (fewer deps; lower table fidelity).
#DOCLING_ENABLED=auto
# DOCS_DIR — where uploaded originals + rendered brochure covers are stored.
#DOCS_DIR=/data/uploads
# Worker queue: how often it polls, and when it reclaims a run a crashed worker
#   abandoned mid-parse (generous — a big/scanned PDF legitimately takes minutes).
#WORKER_POLL_SECONDS=2
#WORKER_STALE_SECONDS=1800

# --- Conversation retention (DPA minimization, not a chat timeout) ---
# SESSION_TTL_DAYS — purge checkpoint rows idle longer than this.
#SESSION_TTL_DAYS=30
# RETENTION_INTERVAL_SECONDS — how often the hourly purge task runs.
#RETENTION_INTERVAL_SECONDS=3600

# --- MCP server ---
# MCP_ALLOWED_HOSTS — Host-header allowlist (streamable HTTP transport). In a
#   cluster, add the in-cluster hostname the agent calls or requests 421.
#MCP_ALLOWED_HOSTS=mcp-server:8002,localhost:8002,127.0.0.1:8002

# --- Internal service URLs (set by the compose files; override only for a
#     non-standard topology) ---
#AGENT_URL=http://localhost:8001         # api → agent
#MCP_HTTP_URL=http://localhost:8002      # api → mcp (REST mirrors)
#MCP_SERVER_URL=http://mcp-server:8002/mcp   # agent → mcp (MCP transport)
#DATABASE_URL=postgresql+psycopg://insurance:insurance@localhost:5432/insurance
