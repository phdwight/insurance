          <mxGeometry x="1150" y="245" width="140" height="90" as="geometry" />
        </mxCell>

        <mxCell id="note-ingest" value="guided: pending answer parsed by the discriminator that asked it (no LLM needed)&#10;freeform: LLM extraction (small model, never guesses), merged non-destructively&#10;deterministic-parse-first: a message that is only the direct answer (chip tap, bare number, line pick) skips the extractor LLM" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fillColor=#fff2cc;strokeColor=#d6b656;size=14;align=left;spacing=6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1150" y="95" width="290" height="95" as="geometry" />
        </mxCell>

        <mxCell id="note-decide" value="deterministic, no LLM:&#10;• attributes ALL candidates share are never asked (e.g. all cover COVID)&#10;• best splitter = most even partition&#10;• stops at ≤3 candidates, no splitter left, or 5-question budget&#10;• budget question = last resort&#10;• empty set = honest no-match" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fillColor=#fff2cc;strokeColor=#d6b656;size=14;align=left;spacing=6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1150" y="390" width="290" height="130" as="geometry" />
        </mxCell>

        <mxCell id="judge1" value="Judge A&#10;e.g. Claude Haiku" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#9673a6;dashed=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1150" y="790" width="140" height="45" as="geometry" />
